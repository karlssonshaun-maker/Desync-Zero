# ── Database ──────────────────────────────────────────────────────────────────
# In docker-compose this points to PgBouncer (port 6432), not Postgres directly.
# For local dev without Docker, point straight at Postgres (port 5432).
DATABASE_URL=postgresql+asyncpg://desync:your_secure_password@localhost:5432/desync_zero
POSTGRES_PASSWORD=your_secure_password

# Set to true when DATABASE_URL points to PgBouncer.
# This switches SQLAlchemy to NullPool so two layers of pooling don't stack.
USE_PGBOUNCER=false

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_64_char_hex_string

# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
CREDENTIAL_ENCRYPTION_KEY=replace_with_32_char_string

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Marketplace defaults ────────────────────────────────────────────────────────
TAKEALOT_API_BASE_URL=https://seller-api.takealot.com/v2
TAKEALOT_RATE_LIMIT_PER_MINUTE=60
AMAZON_RATE_LIMIT_PER_MINUTE=30

# ── Sync / retry ───────────────────────────────────────────────────────────────
SYNC_MAX_RETRIES=5
SYNC_BASE_BACKOFF_SECONDS=1.0
SYNC_MAX_BACKOFF_SECONDS=60.0

DEBUG=false
